{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "npx formalin brief"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx formalin gate \"$CLAUDE_TOOL_INPUT_CONTENT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx formalin snapshot \"$CLAUDE_TOOL_INPUT_FILE_PATH\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "npx formalin check"
      }
    ]
  }
}